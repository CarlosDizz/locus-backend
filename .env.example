APP_NAME=Locus API
APP_ENV=local
APP_BUILD=v2-local
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
AUTH_TOKEN_TTL_DAYS=30

DB_DRIVER=mysql+pymysql
DB_HOST=mysql
DB_PORT=3306
DB_NAME=locus
DB_USER=locus
DB_PASSWORD=locus
DATABASE_URL=mysql+pymysql://locus:locus@mysql:3306/locus

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=locus
MYSQL_USER=locus
MYSQL_PASSWORD=locus

BILLING_MARGIN_MULTIPLIER=1.15
BILLING_USD_TO_EUR=1.00
BILLING_SIGNUP_BONUS_CENTS=200
BILLING_MIN_RESERVE_CENTS=25

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-5.2
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_SECRET_TTL_SECONDS=600

MAPS_API_KEY=
WIKIPEDIA_LANGUAGE=es
WIKIDATA_BASE_URL=https://www.wikidata.org
WIKIDATA_LANGUAGE=es
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql

GEMINI_API_KEY=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=
